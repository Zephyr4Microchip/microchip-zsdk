 * 
 * Erase MCUboot trailer areas to clear any pending upgrade state
 *
 * slot0 trailer: last 8KB of slot0 (@ 0x0C0ED000)
 * slot1 trailer: last 8KB of slot1 (@ 0x0C1DC000)
 */

// Erase slot0 trailer (8KB)
erase 0x0C0ED000, 0x0C0EEFFF

// Erase slot1 trailer (8KB)
erase 0x0C1DC000, 0x0C1DDFFF

r
g
qc
